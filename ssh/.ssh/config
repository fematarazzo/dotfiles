# ~/.ssh/config
# conservative defaults. host-specific entries override below.

Host *
    # protocol
    Protocol 2

    # keys only, no passwords
    PasswordAuthentication no
    PubkeyAuthentication yes
    ChallengeResponseAuthentication no

    # modern algorithms
    HostKeyAlgorithms ssh-ed25519,rsa-sha2-512,rsa-sha2-256
    KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org,diffie-hellman-group16-sha512
    Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com
    MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com

    # persistent connection (speeds up repeated ssh)
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h:%p
    ControlPersist 600

    # keepalive
    ServerAliveInterval 60
    ServerAliveCountMax 3

    # never trust forwarding by default
    ForwardAgent no
    ForwardX11 no

    # hash known_hosts (privacy if it leaks)
    HashKnownHosts yes

    # don't try multiple identity files (avoids lockouts)
    IdentitiesOnly yes

# ── examples (replace with real hosts) ─────────────────
# Host home
#     HostName 192.168.1.10
#     User felipe
#     Port 22022
#     IdentityFile ~/.ssh/id_ed25519_home

# Host github.com
#     User git
#     IdentityFile ~/.ssh/id_ed25519_github
