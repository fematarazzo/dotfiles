# curl — patient defaults
location                       # follow redirects
retry = 5
retry-delay = 3
retry-max-time = 60
connect-timeout = 30
max-time = 600
fail                           # nonzero exit on HTTP errors
silent
show-error
user-agent = "Mozilla/5.0 (X11; Linux x86_64; rv:128.0) Gecko/20100101 Firefox/128.0"
